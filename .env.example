# FlexiDesk Environment Variables
# Copy this file to .env and fill in the values you need.
# All variables are OPTIONAL — the app works fully offline without them.

# ── Supabase (for cloud sync, OAuth, Ask Lena) ──────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── AI Providers (configured in Settings > AI Provider) ──
# These can also be set in-app via the Settings page.
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...
